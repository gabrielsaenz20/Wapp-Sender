SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
DATABASE_URL=sqlite:///./wapp_sender.db

# ---------------------------------------------------------------------------
# Human-simulation settings (anti-detection)
# ---------------------------------------------------------------------------
# Set to false to disable all human-simulation behaviour and use a fixed delay.
HUMAN_SIMULATE=true

# Random delay range (seconds) between consecutive messages.
# A value drawn from [MESSAGE_MIN_DELAY, MESSAGE_MAX_DELAY] is used each time.
MESSAGE_MIN_DELAY=5.0
MESSAGE_MAX_DELAY=20.0

# Typing speed (characters per minute) used to decide how long the "typing…"
# indicator is shown. 200 CPM ≈ 40 WPM, a realistic mobile average.
TYPING_CPM=200.0

# Probability (0.0–1.0) that a "seen" read-receipt is sent before typing.
SEEN_PROBABILITY=0.85

# Legacy fixed delay (seconds) used when HUMAN_SIMULATE=false.
MESSAGE_SEND_DELAY=1.0
